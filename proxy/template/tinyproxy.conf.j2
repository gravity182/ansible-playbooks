# Managed by Ansible.
User tinyproxy
Group tinyproxy

Port {{ tinyproxy_port }}
Listen {{ tinyproxy_listen_address }}
Timeout {{ tinyproxy_timeout }}

DefaultErrorFile "/usr/share/tinyproxy/default.html"
StatFile "/usr/share/tinyproxy/stats.html"

LogFile "/var/log/tinyproxy/tinyproxy.log"
LogLevel {{ tinyproxy_log_level }}
PidFile "/run/tinyproxy/tinyproxy.pid"

MaxClients {{ tinyproxy_max_clients }}

BasicAuth {{ tinyproxy_credentials.username }} {{ tinyproxy_credentials.password }}

ViaProxyName "tinyproxy"
DisableViaHeader Yes

{% for connect_port in tinyproxy_connect_ports %}
ConnectPort {{ connect_port }}
{% endfor %}
